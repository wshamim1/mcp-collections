# Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── AI Model API Keys ─────────────────────────────────────────────────────

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# OpenAI (GPT-4o etc.) — https://platform.openai.com
OPENAI_API_KEY=sk-proj-...your-key-here...

# ─── Local Models ──────────────────────────────────────────────────────────

# Ollama (local, no key needed — just install Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── Servers ───────────────────────────────────────────────────────────────

# Filesystem server base directory
BASE_DIR=/path/to/allowed/directory

# Database server
DB_PATH=./demo.db
READ_ONLY=false

# Auth server
API_KEY=your-secret-api-key-here
ADMIN_KEY=your-admin-key-here

# ─── Optional External APIs ─────────────────────────────────────────────────

# Weather (Open-Meteo is free — no key needed)
# OpenWeatherMap (if you want paid weather data)
# OPENWEATHERMAP_API_KEY=...

# GitHub (for GitHub MCP server examples)
# GITHUB_TOKEN=ghp_...
